generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Info {
  id               Int       @id @default(autoincrement())
  created          DateTime  @default(now())
  uid              Int?
  ts               DateTime?
  name             String?   @db.VarChar(256)
  blGit            String?   @map("bl_git") @db.VarChar(256)
  blStatus         Int?      @map("bl_status")
  appGit           String?   @map("app_git") @db.VarChar(256)
  appVer           Int?      @map("app_ver")
  mcu              String?   @db.VarChar(256)
  apn              String?   @db.VarChar(256)
  urlOta           String?   @map("url_ota") @db.VarChar(256)
  urlApp           String?   @map("url_app") @db.VarChar(256)
  periodUpload     Int?      @map("period_upload")
  periodSensors    Int?      @map("period_sensors")
  periodAnemometer Int?      @map("period_anemometer")
  color            String?   @db.VarChar(16)
  lat              Float?
  lng              Float?

  @@map("info")
}

model Status {
  id           Int       @id @default(autoincrement())
  created      DateTime  @default(now())
  uid          Int?
  ts           DateTime?
  ticks        BigInt?
  tamper       Boolean?
  recordsCount Int?      @map("records_count")

  @@map("status")
}

model SensorRecord {
  id            Int       @id @default(autoincrement())
  created       DateTime  @default(now())
  uid           Int?
  ts            DateTime?
  voltage       Float?
  temperature   Float?
  humidity      Float?
  pressure      Float?
  windDirection Float?    @map("wind_direction")
  windSpeedAvg  Int?      @map("wind_speed_avg")
  windSpeedMin  Int?      @map("wind_speed_min")
  windSpeedMax  Int?      @map("wind_speed_max")

  @@map("sensor_record")
}

model Cnet {
  id      Int       @id @default(autoincrement())
  created DateTime  @default(now())
  uid     Int?
  ts      DateTime?
  mcc     Int?
  mnc     Int?
  lac     Int?
  cid     Int?
  lev     Int?
  lat     Float?
  lng     Float?

  @@map("cnet")
}
