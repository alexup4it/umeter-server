# Postgres password (used by docker-compose and DATABASE_URL)
POSTGRES_PASSWORD=umeter

# Database connection
# - Local dev (docker-compose.dev.yml): postgresql://umeter:umeter@localhost:5432/umeter
# - Production (docker-compose.yml): set automatically via POSTGRES_PASSWORD
DATABASE_URL="postgresql://umeter:umeter@localhost:5432/umeter"

# HMAC Secret (32 bytes as hex)
HMAC_SECRET="abababababababababababababababababababababababababababababababab"

OPENCELL_API_KEY=""

# Firmware directory for OTA updates (default: ./firmware)
# In production (docker-compose.yml) this is set to /app/firmware (volume mount)
FIRMWARE_DIR="./data/firmware"

# Allowed dev origins (comma-separated, for Next.js dev server)
# ALLOWED_DEV_ORIGINS="myhost.ddns.net,localhost"

# Public app port (default: 3000)
# APP_PORT=3000
